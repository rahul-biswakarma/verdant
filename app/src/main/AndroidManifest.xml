<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Location ──────────────────────────────────────────────────────── -->
    <!-- Required for Location-type habit tracking (check-in, distance) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- ── Notification ──────────────────────────────────────────────────── -->
    <!-- Required on Android 13+ (API 33) to post notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ── Exact alarms ──────────────────────────────────────────────────── -->
    <!--
        USE_EXACT_ALARM is granted automatically on API 33+ for alarm-clock /
        reminder use cases and does NOT require a user prompt.
        SCHEDULE_EXACT_ALARM is the older pre-33 permission (auto-granted).
    -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- ── Boot ──────────────────────────────────────────────────────────── -->
    <!-- Required to receive ACTION_BOOT_COMPLETED and re-register alarms -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- ── Wake lock (WorkManager / foreground workers) ─────────────────── -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ── SMS (Finance product — bank transaction tracking) ──────────── -->
    <uses-permission android:name="android.permission.READ_SMS" />

    <application
        android:name=".VerdantApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Verdant">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Verdant"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Disable the default WorkManager auto-initializer so VerdantApplication
            can supply a custom Configuration backed by HiltWorkerFactory.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- ── Notification action receiver ────────────────────────────── -->
        <!--
            Handles Done / Skip / Snooze taps from streak-nudge and reminder
            notifications. Not exported — only internal PendingIntents fire it.
        -->
        <receiver
            android:name="com.verdant.work.receiver.NotificationActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.verdant.work.ACTION_DONE" />
                <action android:name="com.verdant.work.ACTION_SKIP" />
                <action android:name="com.verdant.work.ACTION_SNOOZE" />
                <action android:name="com.verdant.work.ACTION_SNOOZE_FIRE" />
            </intent-filter>
        </receiver>

        <!-- ── Reminder alarm receiver ──────────────────────────────────── -->
        <!--
            Fired by AlarmManager when a habit reminder is due. Not exported —
            only PendingIntents constructed by ReminderScheduler fire it.
        -->
        <receiver
            android:name="com.verdant.work.receiver.ReminderAlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.verdant.work.ACTION_FIRE_REMINDER" />
            </intent-filter>
        </receiver>

        <!-- ── Boot receiver ────────────────────────────────────────────── -->
        <!--
            Re-registers AlarmManager alarms after a device reboot.
            Must be exported so the system can deliver ACTION_BOOT_COMPLETED.
        -->
        <receiver
            android:name="com.verdant.work.receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <!-- OEM alternative -->
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
